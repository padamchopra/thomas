{
  "name": "thomas",
  "version": "0.1.0",
  "description": "A local-first Node.js server and React UI for agent work orchestration.",
  "bin": {
    "thomas": "./bin/thomas.js"
  },
  "scripts": {
    "check": "node --check bin/thomas.js && node --check src/server/index.js && node --check src/server/app.js && node --check src/server/agent-runner.js && node --check src/core/state-store.js && node --check src/core/thomas-service.js",
    "dev": "npm run dev:server",
    "dev:server": "node bin/thomas.js serve",
    "dev:ui": "vite --host 127.0.0.1 --config ui/vite.config.mjs",
    "build": "vite build --config ui/vite.config.mjs",
    "start": "node bin/thomas.js serve",
    "test": "node --test"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.574.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  }
}
